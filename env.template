# ─── JARVIS .env ───────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys

# ── GROQ (primary, ultra-fast) ─────────────────────────────────────────────────
# Get free key → https://console.groq.com
GROQ_API_KEY=

# ── ANTHROPIC (fallback + Claude Code tasks) ────────────────────────────────────
# Get key → https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── ELEVENLABS (British voice TTS) ─────────────────────────────────────────────
# Get key → https://elevenlabs.io
# Recommended voice: "Daniel" (British male) — find ID in ElevenLabs dashboard
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Optional: Voice model override ─────────────────────────────────────────────
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
